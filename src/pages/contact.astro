---
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>contact — senja studio</title>
	</head>
	<body>
		<div class="absolute top-4 left-12 z-10">
			<a href="/" class="block text-lg leading-tight font-normal" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0.05em; color: #1c1c1c; text-transform: uppercase;">senja studio</a>
			<p class="mt-1 text-sm font-[325]" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0.02em; color: #aeaeae;"><a href="/hotels" class="transition-colors hover:text-[#1c1c1c] hover:underline">hotels and stays</a> / <a href="/food" class="transition-colors hover:text-[#1c1c1c] hover:underline">food and spaces</a> / <a href="/outdoors" class="transition-colors hover:text-[#1c1c1c] hover:underline">outdoors</a> / <a href="/ugc" class="transition-colors hover:text-[#1c1c1c] hover:underline">user generated content</a></p>
			<p class="text-sm font-[325]" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0.02em; color: #aeaeae;"><a href="/about" class="transition-colors hover:text-[#1c1c1c] hover:underline">about</a> / <a href="/contact" class="text-[#1c1c1c] underline">contact</a></p>
		</div>

		<a href="/" class="absolute top-4 right-6 z-10 text-lg leading-tight font-normal text-[#1c1c1c] transition-colors hover:text-neutral-300" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">✕</a>


		<main class="min-h-screen px-6 pb-24 pt-28">
			<div class="ml-[29vw] max-w-xl space-y-12 text-justify text-sm font-[325] leading-relaxed" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0.02em; color: #1c1c1c;">
				<p class="text-xl font-medium">let's get in touch</p>
				<p>Whether you’re a boutique hotel, a resort, a restaurant, a concept store or an alternative venue — if you want content that’s ready to post and actually performs, let’s talk about your project.</p>

				<form class="space-y-3 text-left">
					<input type="text" placeholder="Your name" class="w-full border-b border-neutral-300 bg-transparent pb-2 text-sm outline-none placeholder:text-neutral-400 focus:border-[#1c1c1c]" />
					<input type="text" placeholder="Property / Brand name" class="w-full border-b border-neutral-300 bg-transparent pb-2 text-sm outline-none placeholder:text-neutral-400 focus:border-[#1c1c1c]" />
					<input type="text" placeholder="Type of venue" class="w-full border-b border-neutral-300 bg-transparent pb-2 text-sm outline-none placeholder:text-neutral-400 focus:border-[#1c1c1c]" />
					<input type="text" placeholder="Country and city" class="w-full border-b border-neutral-300 bg-transparent pb-2 text-sm outline-none placeholder:text-neutral-400 focus:border-[#1c1c1c]" />
					<textarea placeholder="Tell me about your project" rows="3" class="w-full resize-none border-b border-neutral-300 bg-transparent pb-2 text-sm outline-none placeholder:text-neutral-400 focus:border-[#1c1c1c]"></textarea>
					<button type="submit" class="pt-2 text-sm font-medium transition-colors hover:text-neutral-400">send my request</button>
				</form>

				<p>Prefer to reach out directly? <a href="mailto:hello@senjastudio.com" class="font-medium transition-colors hover:text-neutral-400">hello@senjastudio.com</a></p>
			</div>
		</main>
	</body>
</html>
