		<script>
			const main = document.getElementById('hscroll');
			const track = document.getElementById('htrack');
			const figs = Array.from(track.querySelectorAll('figure'));
			const numEl = document.getElementById('idx-num');
			const themeEl = document.getElementById('idx-theme');
			const listEl = document.getElementById('idx-list');
			const rows = listEl ? Array.from(listEl.querySelectorAll('p[data-i]')) : [];
			const themes = ['XX', 'YY', 'ZZ', 'AA', 'BB', 'CC'];
			const N = 12;
			const ROW = 1.2;
			let centers = figs.map((f) => f.offsetTop + f.offsetHeight / 2);
			let vw = window.innerHeight;
			let setWidth = figs[N].offsetTop - figs[0].offsetTop;
			let target = 0;
			let current = 0;
			let activeBi = -1;
			let activeM = -1;
			let reelIdx = N;
			let prevCountry = 0;
			let idle = 0;
			let snapped = false;
			const measure = () => {
				centers = figs.map((f) => f.offsetTop + f.offsetHeight / 2);
				vw = window.innerHeight;
				setWidth = figs[N].offsetTop - figs[0].offsetTop;
			};
			window.addEventListener('resize', measure);
			main.addEventListener('wheel', (e) => {
				e.preventDefault();
				let d = Math.abs(e.deltaY) > Math.abs(e.deltaX) ? e.deltaY : e.deltaX;
				if (e.deltaMode === 1) d *= 16;
				else if (e.deltaMode === 2) d *= vw;
				target += d;
				idle = 0;
				snapped = false;
			}, { passive: false });
			const placeReel = () => {
				listEl.style.transform = 'translateY(' + ((4 - reelIdx) * ROW) + 'em)';
				rows.forEach((r) => r.classList.toggle('on', Number(r.dataset.i) === reelIdx));
			};
			const setReel = (country) => {
				let diff = country - prevCountry;
				if (diff > N / 2) diff -= N;
				if (diff < -N / 2) diff += N;
				reelIdx += diff;
				prevCountry = country;
				if (reelIdx < N || reelIdx >= 2 * N) {
					reelIdx = N + (((reelIdx % N) + N) % N);
				}
				placeReel();
			};
			const updateActive = (vis) => {
				const targetPos = vis + vw / 2;
				let bi = 0;
				let bd = Infinity;
				for (let i = 0; i < centers.length; i++) {
					const dd = Math.abs(centers[i] - targetPos);
					if (dd < bd) { bd = dd; bi = i; }
				}
				if (bi !== activeBi) {
						activeBi = bi;
						const m = bi % N;
						if (m !== activeM) {
							activeM = m;
							for (let i = 0; i < figs.length; i++) figs[i].classList.toggle('is-active', i % N === m);
							if (numEl) numEl.textContent = String(m + 1).padStart(2, '0');
							if (themeEl) themeEl.textContent = themes[m % themes.length];
							setReel(m);
						}
					}

				return centers[bi] - targetPos;
			};
			placeReel();
			const raf = () => {
				current += (target - current) * 0.08;
				const vis = (((current % setWidth) + setWidth) % setWidth);
				track.style.transform = 'translate3d(0, ' + (-vis) + 'px, 0)';
				const bestD = updateActive(vis);
				idle++;
				if (!snapped && idle > 8 && Math.abs(target - current) < 1.5) {
					target += bestD;
					snapped = true;
				}
				requestAnimationFrame(raf);
			};
			requestAnimationFrame(raf);
		</script>






	</body>
