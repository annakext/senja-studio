---
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital@0;1&display=swap" rel="stylesheet" />
		<title>hotels and stays — senja studio</title>
	</head>
	<body>
		<div class="fixed inset-y-0 right-0 w-1/2 -z-10" style="background-color: #f3f1ee;"></div>
		<a href="/" class="absolute top-3 left-6 z-10 block text-lg leading-tight font-normal" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0.05em; color: #1c1c1c; text-transform: uppercase;">senja studio</a>

		<p class="absolute top-1/2 left-6 z-10 -translate-y-1/2 text-[0.8125rem] font-[325]" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0; color: #1c1c1c;">hotels and stays</p>
		<div class="absolute top-1/2 left-[18vw] z-10 text-[0.8125rem] font-[325] leading-[1.6em]" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 0; color: #1c1c1c; transform: translateY(-0.8em);">
			<p>Photography, Video</p>
			<p>User Generated Content</p>
		</div>






		<main class="min-h-screen pl-[51vw] pr-8 pb-24 pt-40">
			<div class="grid grid-cols-4 gap-4">
				<img src="/images/ugc-hs/1.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover object-bottom" />
				<img src="/images/ugc-hs/2.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover object-bottom" />
				<img src="/images/ugc-hs/3.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<div class="aspect-[3/4] w-full border-[3px] border-white bg-neutral-200"></div>
				<img src="/images/ugc-hs/5-bis.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<img src="/images/ugc-hs/6-bis.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<img src="/images/ugc-hs/4.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<div class="aspect-[3/4] w-full border-[3px] border-white bg-neutral-200"></div>
				<img src="/images/ugc-hs/9.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<img src="/images/ugc-hs/10.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<img src="/images/ugc-hs/11.jpg" alt="" class="aspect-[3/4] w-full border-[3px] border-white object-cover" />
				<div class="aspect-[3/4] w-full border-[3px] border-white bg-neutral-200"></div>
			</div>

		</main>
	</body>
</html>
